# Brain OS 环境变量配置
# 复制此文件为 .env 并修改相应值

# Hermes 根目录（默认: ~/.hermes）
HERMES_ROOT=~/.hermes

# 知识库路径（默认: $HERMES_ROOT/knowledge）
HERMES_KNOWLEDGE=${HERMES_ROOT}/knowledge

# todo-backlog.md 路径（默认: $HERMES_KNOWLEDGE/06-context/todo-tracking/todo-backlog.md）
HERMES_TODO_PATH=${HERMES_KNOWLEDGE}/06-context/todo-tracking/todo-backlog.md

# Kanban 默认分配人（默认: default）
HERMES_KANBAN_ASSIGNEE=default

# 可选：自定义追踪器目录
# HERMES_TRACKERS_DIR=${HERMES_KNOWLEDGE}/99-system/trackers
